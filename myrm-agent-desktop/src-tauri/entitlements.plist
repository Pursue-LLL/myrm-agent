<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Hardened Runtime entitlements for MyrmAgent.app

        Required by tauri.conf.json#bundle.macOS.hardenedRuntime: true.
        Without these entitlements, Apple Notary Service signs successfully
        but the runtime denies:
          - WebView V8 JIT execution
          - Python/Node sidecar child processes
          - AppleScript System Events for window text extraction (Appshot)
          - Cloudflared tunnel binary loading

        Keep this list minimal: each entitlement triggers Apple notary review.
        TCC permissions (screen recording, accessibility) are granted by
        users via System Settings, not via this plist. Microphone requires
        the audio-input entitlement below to trigger the TCC prompt.
    -->

    <!-- WebView V8 engine -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Tauri internals + dyld lookup for sidecar -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- osascript / System Events for Appshot window text extraction -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Microphone for voice input (pairs with NSMicrophoneUsageDescription) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
