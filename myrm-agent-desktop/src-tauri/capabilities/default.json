{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-progress-bar",
    "core:window:allow-request-user-attention",
    "clipboard-manager:default",
    "dialog:default",
    "shell:default"
  ]
}
