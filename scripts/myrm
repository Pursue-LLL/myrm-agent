#!/usr/bin/env bash
# Myrm CLI — WebUI lifecycle (OSS myrm-agent repo)
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
# shellcheck source=lib/resolve_agent_root.sh
source "${SCRIPT_DIR}/lib/resolve_agent_root.sh"
# shellcheck source=lib/start_server.sh
source "${SCRIPT_DIR}/lib/start_server.sh"
resolve_agent_paths "${PROJECT_ROOT}"

COMPOSE_FILE="${SERVER_DIR}/docker-compose.yaml"
MYRM_PROCESS_PATTERN='[m]yrm-agent-server/run.py|[m]yrm-agent-server/.venv.*run.py'

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'
BOLD='\033[1m'

show_help() {
    echo -e "${CYAN}${BOLD}MyrmAgent CLI${NC}"
    echo "Usage: myrm <command>"
    echo "  setup              First-time deps (uv sync + bun install)"
    echo "  dev                Backend :8080 in background + health wait"
    echo "  start              Dev backend :8080 (foreground)"
    echo "  start --standalone  All-in-one WebUI :25808"
    echo "  stop | status | update"
    echo "  searxng start | stop | status"
    echo ""
    echo "Quick dev: myrm dev && cd myrm-agent-frontend && bun run dev"
}

require_docker() {
    command -v docker &>/dev/null || { echo -e "${RED}Docker required${NC}"; exit 1; }
    [[ -f "$COMPOSE_FILE" ]] || { echo -e "${RED}Missing compose file${NC}"; exit 1; }
}

searxng_start() {
    require_docker
    (cd "$SERVER_DIR" && docker compose --profile search up -d)
    echo -e "${GREEN}SearXNG: http://127.0.0.1:8081${NC}"
}

searxng_stop() {
    require_docker
    (cd "$SERVER_DIR" && docker compose --profile search down)
}

searxng_status() {
    require_docker
    (cd "$SERVER_DIR" && docker compose --profile search ps)
}

cd "$PROJECT_ROOT"
COMMAND=${1:-}
shift || true

case "$COMMAND" in
    setup)
        exec "${SCRIPT_DIR}/dev/setup.sh"
        ;;

    dev)
        exec "${SCRIPT_DIR}/dev/dev.sh" "$@"
        ;;

    start)
        start_args=()
        for arg in "$@"; do
            case "$arg" in
                --standalone|--webui) start_args+=(--webui) ;;
            esac
        done
        if [[ ${#start_args[@]} -gt 0 ]]; then
            echo -e "${GREEN}🚀 Starting standalone WebUI (backend :25808)...${NC}"
            start_myrm_server "$SERVER_DIR" "${start_args[@]}"
        else
            echo -e "${GREEN}🚀 Starting dev backend (http://127.0.0.1:8080)${NC}"
            echo -e "${CYAN}ℹ️  Frontend: cd myrm-agent-frontend && bun run dev  →  http://localhost:3000${NC}"
            start_myrm_server "$SERVER_DIR"
        fi
        ;;
    stop)
        if [[ -f "${SERVER_DIR}/.myrm-dev-backend.pid" ]]; then
            dev_pid="$(cat "${SERVER_DIR}/.myrm-dev-backend.pid")"
            kill "${dev_pid}" 2>/dev/null || true
            rm -f "${SERVER_DIR}/.myrm-dev-backend.pid"
        fi
        pids=$(ps aux | grep -E "$MYRM_PROCESS_PATTERN|[n]ext dev|[b]un run dev" | awk '{print $2}')
        [[ -n "$pids" ]] && kill -9 $pids || true
        ;;
    status)
        pids=$(ps aux | grep -E "$MYRM_PROCESS_PATTERN|[n]ext dev|[b]un run dev" | awk '{print $2}')
        [[ -n "$pids" ]] && echo "Running: $pids" || echo "Not running"
        ;;
    update)
        git pull --ff-only
        (cd "$SERVER_DIR" && uv sync --all-extras)
        (cd "$FRONTEND_DIR" && bun install && bun run build)
        ;;
    searxng)
        SUBCMD=${1:-}
        case "$SUBCMD" in
            start) searxng_start ;;
            stop) searxng_stop ;;
            status) searxng_status ;;
            *) show_help; exit 1 ;;
        esac
        ;;
    ""|help|-h|--help) show_help ;;
    *) show_help; exit 1 ;;
esac
