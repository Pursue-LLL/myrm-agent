# MyrmAgent Server — sandbox [S] only
# =============================================================================
# WHO: myrm-agent-server when DEPLOY_MODE=sandbox (one server per user sandbox).
# NOT the Control Plane's own config — CP injects these vars into the container at
# spawn time (injected by the control service when creating the sandbox container).
# USE:
#   • Production SaaS: CP injects env programmatically; this file is the contract doc.
#   • Local dev: cp .env.sandbox.example .env.sandbox + DEPLOY_MODE=sandbox to simulate.
# POLICY: Business LLM/Search/Embedding → WebUI DB inside the sandbox, not here.
# =============================================================================
# Merge into environment when DEPLOY_MODE=sandbox
# Copy: cp .env.sandbox.example .env.sandbox

# =============================================================================
# [S] Sandbox authentication & encryption
# =============================================================================

# MYRM_MASTER_KEY=
# SANDBOX_API_KEY=
# CONFIG_ENCRYPTION_KEY=
# INTERNAL_SERVICE_KEY=

# VERCEL_PLATFORM_TOKEN=
# Optional platform Vercel token for SaaS one-click deploy (no user BYOK required).
# Injected by Control Plane when spawning sandbox containers.

# =============================================================================
# [S] Control plane connectivity
# =============================================================================

# CP_PUBLIC_INGRESS_URL=
# CONTROL_PLANE_URL=
# CONTROL_PLANE_TELEMETRY_TOKEN=
# CONTROL_PLANE_TELEMETRY_SUBJECT=
# SANDBOX_ID=
# TENANT_ID=

# =============================================================================
# [S] Platform billing & skill optimization
# =============================================================================

# PLATFORM_WU_PER_USD=1000
# TELEMETRY_PUSH_INTERVAL=3600
# BASELINE_SYNC_INTERVAL=86400
# SKILL_OPTIMIZATION_STORAGE_TYPE=memory

# =============================================================================
# [S] Context compaction telemetry
# =============================================================================

# CONTEXT_COMPACTION_TELEMETRY_BATCH_SIZE=16
# CONTEXT_COMPACTION_TELEMETRY_FLUSH_INTERVAL_SECONDS=2.0
# CONTEXT_COMPACTION_TELEMETRY_QUEUE_SIZE=256
#
# MEMORY_BRIEF_STATUS_TELEMETRY_BATCH_SIZE=32
# MEMORY_BRIEF_STATUS_TELEMETRY_FLUSH_INTERVAL_SECONDS=3.0
# MEMORY_BRIEF_STATUS_TELEMETRY_QUEUE_SIZE=512

# =============================================================================
# [S] Federated wiki volumes (semicolon-separated paths)
# =============================================================================

# MYRM_PUBLIC_WIKI_VOLUMES=

# =============================================================================
# [O] Visual desktop (docker entrypoint)
# =============================================================================

# VISUAL_DESKTOP=1

# =============================================================================
# [S] Bash audit alerting (optional in sandbox)
# =============================================================================

# BASH_AUDIT_WEBHOOK_URL=
# BASH_AUDIT_SLACK_WEBHOOK=

# =============================================================================
# [S] S3 object storage
# =============================================================================

# S3_ENDPOINT_URL=
# S3_BUCKET_NAME=myrm
# S3_REGION=auto
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# [S] AppSettings sandbox fields — see also AppSettings index in .env.example
# =============================================================================
# All vars in sections above map to app/config/settings.py:
#   sandbox_api_key, config_encryption_key, internal_service_key, cp_public_ingress_url
#   control_plane.*, context_compaction_telemetry.*, storage.*, skill_optimization_storage_type
