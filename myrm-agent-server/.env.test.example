# MyrmAgent Server — dev/test only [T]
# =============================================================================
# POLICY:
#   • ONLY for local pytest / E2E development — server production NEVER reads this file.
#   • Loaded exclusively by tests/support/test_secrets.py (via tests/conftest.py).
#   • Business-tier keys here (BASIC_*, LITE_*, SEARCH_*) simulate WebUI providers in tests.
#     Production business config MUST come from WebUI Settings (DB) + inject.
# =============================================================================
# Copy: cp .env.test.example .env.test

# =============================================================================
# [T] LLM providers — pytest/E2E only (mirrors WebUI provider rows, not server env)
# =============================================================================

# BASIC_API_KEY=
# BASIC_BASE_URL=
# BASIC_MODEL=
# LITE_API_KEY=
# LITE_BASE_URL=
# LITE_MODEL=

# =============================================================================
# [T] Search services (business tier — pytest only)
# =============================================================================

# SEARCH_SERVICE=tavily
# TAVILY_API_KEY=
# SEARXNG_URL=http://localhost:8888
# SEARXNG_ENGINE=general

# =============================================================================
# [T] Embedding / reranker (business tier — pytest only)
# =============================================================================

# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_PROVIDER=
# RERANKER_MODEL=
# RERANKER_API_KEY=
# RERANKER_BASE_URL=

# =============================================================================
# [T] OAuth & E2E URLs
# =============================================================================

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FRONTEND_URL=http://localhost:3000
# BACKEND_URL=http://localhost:8080
# TEST_BASE_URL=http://localhost:8080
# TEST_USERNAME=
# TEST_PASSWORD=

# =============================================================================
# [T] Test harness toggles (optional)
# =============================================================================

# PYTEST_CURRENT_TEST — set automatically by pytest; do not add to this file

# RUN_E2E_TESTS=1
# RUN_OPENAI_COMPAT_E2E=1
# MYRM_E2E_REAL_FRONTEND_STACK=1
# MYRM_E2E_SKIP_MODEL_SETUP=1
# MYRM_E2E_FRONTEND_URL=http://localhost:3000
# MYRM_E2E_BACKEND_URL=http://localhost:8080
# MYRM_E2E_ARCHIVE_CHECKPOINT=1
# MYRM_SMOKE_BASE_URL=
# MYRM_SMOKE_API_KEY=
# MYRM_SMOKE_RUN_ID=
# MYRM_SMOKE_ENABLE_CHAT_RECALL=1
# MYRM_HOME=
# MYRM_DATA_DIR=

# =============================================================================
# [T] Optional test fallbacks (embedding E2E helpers only — not server runtime)
# =============================================================================

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# =============================================================================
# [T] Complete test env index (pytest only — mirrors WebUI business config for E2E)
# =============================================================================
# LLM: BASIC_API_KEY, BASIC_BASE_URL, BASIC_MODEL, LITE_API_KEY, LITE_BASE_URL, LITE_MODEL
# Search: SEARCH_SERVICE, TAVILY_API_KEY, SEARXNG_URL, SEARXNG_ENGINE
# Embedding: EMBEDDING_MODEL, EMBEDDING_API_KEY, EMBEDDING_BASE_URL, EMBEDDING_PROVIDER
# Reranker: RERANKER_MODEL, RERANKER_API_KEY, RERANKER_BASE_URL
# OAuth: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
# URLs: FRONTEND_URL, BACKEND_URL, TEST_BASE_URL, MYRM_E2E_FRONTEND_URL, MYRM_E2E_BACKEND_URL
# Auth: TEST_USERNAME, TEST_PASSWORD
# Toggles: RUN_E2E_TESTS, RUN_OPENAI_COMPAT_E2E, MYRM_E2E_* , MYRM_SMOKE_*
# Workspace: MYRM_HOME, MYRM_DATA_DIR (isolated by tests/conftest.py in unit tests)
# Fallbacks: OPENAI_API_KEY, ANTHROPIC_API_KEY (embedding E2E helpers only)
