# MyrmAgent Server — environment reference
# =============================================================================
# POLICY (mandatory):
#   • Only [P] process and [O] ops env vars belong in .env — see sections below.
#   • Business capabilities (LLM / Embedding / Search / providers) → WebUI Settings
#     (DB) and request-time injection ONLY — never .env for production runtime.
#   • [S] sandbox vars → .env.sandbox.example (DEPLOY_MODE=sandbox)
#   • [T] dev/test secrets → .env.test.example (pytest only; server never reads it)
# =============================================================================
# Tier: [P] Process | [O] Ops | [S] Sandbox | [T] Test
# Copy: cp .env.example .env

# =============================================================================
# [P] Process — server boot & workspace
# =============================================================================

# DEPLOY_MODE=local | tauri | sandbox  (webui uses DEPLOY_MODE=local + WEBUI_MODE=true)
DEPLOY_MODE=local

# [P] HTTP listen address and port
HOST=0.0.0.0
PORT=8080

# [P] Root data directory; all derived paths hang off this
MYRM_DATA_DIR=~/.myrm

# [P] Project root for sandbox bind mounts (default: current dir)
# MYRM_PROJECT_DIR=.

# [P] Override derived paths (empty = auto under MYRM_DATA_DIR)
# EVENT_LOG_DIR=
# MEMORY_BASE_PATH=

# [P] Checkpointer backend: memory (ephemeral) or sqlite (default, persistent on volume)
# CHECKPOINTER_MODE=

# [P] Optional Apache AGE graph store (empty = SQLite graph under MYRM_DATA_DIR)
# DATABASE_URL=

# [P] Remote Qdrant (empty = local path under workspace)
# QDRANT_URL=
# QDRANT_API_KEY=

# [P] Patchright/Playwright browser binary cache (tauri/desktop)
# PATCHRIGHT_BROWSERS_PATH=~/Library/Caches/ms-playwright
# PLAYWRIGHT_BROWSERS_PATH=~/Library/Caches/ms-playwright

# [P] Attach to existing Chrome via CDP (local dev)
# CDP_PORT=9222

# =============================================================================
# [O] Ops — server runtime toggles
# =============================================================================

# [O] Pre-warm browser sessions on startup (restore login state)
BROWSER_AUTO_WARMUP=false

# [O] Auth token for browser extension WebSocket endpoint (leave empty to disable auth)
# EXTENSION_AUTH_TOKEN=

# [O] Verbose logging — single reader: app/config/env.py is_debug_mode()
# DEBUG=true

# [O] Skip startup health probe
# SKIP_HEALTH_CHECK=true

# [O] ASGI server: uvicorn (default) or granian
# SERVER_MODE=granian
# GRANIAN_WORKERS=4

# [O] Embedded WebUI pairing server mode
# WEBUI_MODE=true
# WEBUI_REMOTE_MODE=true

# LITELLM_LOG removed — not read by server; use DEBUG for verbose server logs
# [O] Browser pool — env prefix GLOBAL_BROWSER_POOL_
# (tauri/webui auto-tuned; override only when needed)
# =============================================================================

# GLOBAL_BROWSER_POOL_MAX_BROWSERS=5
# GLOBAL_BROWSER_POOL_WARMUP_BROWSERS=2
# GLOBAL_BROWSER_POOL_WARMUP_PAGES=5

# =============================================================================
# [O] Agent gateway — env prefix AGENT_
# =============================================================================

# AGENT_MAX_CONCURRENT=20
# AGENT_MAX_PER_USER=3
# AGENT_QUEUE_TIMEOUT=10.0
# AGENT_EXECUTION_TIMEOUT=300.0

# =============================================================================
# [O] Code execution — env prefix CODE_EXECUTION_
# =============================================================================

# CODE_EXECUTION_ALLOW_NETWORK=true
# CODE_EXECUTION_ALLOWED_HOSTS=

# =============================================================================
# [O] MCP security — env prefix MCP_
# =============================================================================

MCP_ALLOW_STDIO=true
# MCP_REQUIRE_HTTPS=true
# MCP_ENABLE_SSRF_PROTECTION=true
# MCP_VERIFY_TIMEOUT=10
# MCP_MAX_RESPONSE_SIZE=10485760

# =============================================================================
# [O] Rate limits — env prefix RATE_LIMIT_
# =============================================================================

# RATE_LIMIT_CHAT=30/minute;500/hour
# RATE_LIMIT_LOGIN=5/minute;20/hour
# RATE_LIMIT_FILE_UPLOAD=10/hour
# RATE_LIMIT_MCP_VERIFY=10/minute;100/hour
# RATE_LIMIT_REGISTER=3/hour
# RATE_LIMIT_WEBHOOK=60/minute;300/hour

# =============================================================================
# [O] API security — env prefix SECURITY_
# =============================================================================

# SECURITY_SIGNATURE_ENABLED=false
# SECURITY_SSO_PROXY_ENABLED=false
# SECURITY_SSO_PROXY_HEADER=Remote-User
# SECURITY_SSO_PROXY_TRUSTED_IPS=127.0.0.1,::1
# SECURITY_TIMESTAMP_WINDOW=60
# SECURITY_NONCE_TTL=120

# [O] Workspace encryption master key (local/tauri)
# MYRM_MASTER_KEY=

# =============================================================================
# [O] Chat message filter
# =============================================================================

# MESSAGE_FILTER_ENABLED=true
# ADMIN_API_KEYS=

# =============================================================================
# [O] Feature toggles — env prefix ENABLE_
# =============================================================================

# ENABLE_PROMPT_CACHING=true
# ENABLE_BATCH_CLEANUP=true

# [O] Observability — METRICS_ENABLED, OTEL_*
# =============================================================================

# METRICS_ENABLED=false
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SAMPLE_RATE=0.1

# =============================================================================
# [O] DingTalk channel HTTP — env prefix CHANNEL_DINGTALK_
# =============================================================================

# CHANNEL_DINGTALK_TIMEOUT=15
# CHANNEL_DINGTALK_MEDIA_TIMEOUT=30
# CHANNEL_DINGTALK_DOWNLOAD_TIMEOUT=60

# =============================================================================
# [O] WebUI sub-server — env prefix WEBUI_
# =============================================================================

# WEBUI_HOST=127.0.0.1
# WEBUI_PORT=25808
# WEBUI_ALLOW_REMOTE=false
# WEBUI_TOKEN_EXPIRY=900
# WEBUI_TOKEN_MAX_PER_HOUR=10
# WEBUI_QRCODE_SIZE=400
# WEBUI_QRCODE_BORDER=1
# WEBUI_SETUP_TOKEN=  # [O] one-time first-run setup token override (temp_token.py)

# =============================================================================
# [O] Subagent global defaults — per-agent tuning lives in app/config/subagents/*.yaml
# =============================================================================

# =============================================================================
# [O] Server integrations
# =============================================================================

# GITHUB_TOKEN=
# CRON_FAILURE_WEBHOOK_URL=

# =============================================================================
# [O] Bash audit alerting — env prefix BASH_AUDIT_
# =============================================================================

# BASH_AUDIT_WEBHOOK_URL=
# BASH_AUDIT_SLACK_WEBHOOK=

# =============================================================================
# [O] Storage mode override (see deploy_mode.py)
# =============================================================================

# STORAGE_MODE=local

# =============================================================================
# [O] Auth audit log rotation
# =============================================================================

# AUTH_AUDIT_LOG_MAX_SIZE_MB=10
# AUTH_AUDIT_LOG_MAX_AGE_DAYS=7
# AUTH_AUDIT_LOG_RETENTION_DAYS=30
# AUTH_AUDIT_LOG_COMPRESS=true

# =============================================================================
# [O] Harness event log
# =============================================================================

# EVENT_LOG_MAX_JSONL_LINE_BYTES=102400

# =============================================================================
# [O] Database tuning
# =============================================================================

# SQLITE_POOL_SIZE=5
# SQLITE_BUSY_TIMEOUT_MS=3000
# DATABASE_ECHO=false
# POSTGRES_TRANSIENT_RETRY_AFTER_SECONDS=3

# =============================================================================
# [O] Auth & CORS
# =============================================================================

# HCAPTCHA_SECRET_KEY=
# CORS_ORIGINS=

# =============================================================================
# [O] Google Workspace OAuth (Settings → Integrations → Credentials)
# =============================================================================

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# =============================================================================
# [S] Sandbox — see .env.sandbox.example (merge when DEPLOY_MODE=sandbox)
# [T] Dev/test only — see .env.test.example (pytest via tests/support/test_secrets.py)
# =============================================================================

# =============================================================================
# AppSettings complete index (app/config/settings.py — authoritative code map)
# =============================================================================
# [P] PORT, HOST, MYRM_DATA_DIR, MYRM_PROJECT_DIR, EVENT_LOG_DIR, MEMORY_BASE_PATH
#     CHECKPOINTER_MODE, DATABASE_URL, QDRANT_URL, QDRANT_API_KEY
#     PATCHRIGHT_BROWSERS_PATH, PLAYWRIGHT_BROWSERS_PATH (optional override)
# [O] CORS_ORIGINS, BROWSER_AUTO_WARMUP, HCAPTCHA_SECRET_KEY, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
#     AUTH_AUDIT_LOG_MAX_SIZE_MB, AUTH_AUDIT_LOG_MAX_AGE_DAYS, AUTH_AUDIT_LOG_RETENTION_DAYS, AUTH_AUDIT_LOG_COMPRESS
#     EVENT_LOG_MAX_JSONL_LINE_BYTES, GITHUB_TOKEN, CRON_FAILURE_WEBHOOK_URL
#     ENABLE_PROMPT_CACHING, ENABLE_BATCH_CLEANUP
#     MESSAGE_FILTER_ENABLED, ADMIN_API_KEYS
#     BASH_AUDIT_WEBHOOK_URL, BASH_AUDIT_SLACK_WEBHOOK
#     METRICS_ENABLED, OTEL_ENABLED, OTEL_EXPORTER_OTLP_ENDPOINT, OTEL_SAMPLE_RATE
#     CHANNEL_DINGTALK_TIMEOUT, CHANNEL_DINGTALK_MEDIA_TIMEOUT, CHANNEL_DINGTALK_DOWNLOAD_TIMEOUT
#     MCP_ALLOW_STDIO, MCP_REQUIRE_HTTPS, MCP_ENABLE_SSRF_PROTECTION, MCP_VERIFY_TIMEOUT, MCP_MAX_RESPONSE_SIZE
#     RATE_LIMIT_MCP_VERIFY, RATE_LIMIT_CHAT, RATE_LIMIT_FILE_UPLOAD, RATE_LIMIT_LOGIN, RATE_LIMIT_REGISTER, RATE_LIMIT_WEBHOOK
#     GLOBAL_BROWSER_POOL_MAX_BROWSERS, GLOBAL_BROWSER_POOL_WARMUP_BROWSERS, GLOBAL_BROWSER_POOL_WARMUP_PAGES
#     CODE_EXECUTION_ALLOW_NETWORK, CODE_EXECUTION_ALLOWED_HOSTS
#     SECURITY_SIGNATURE_ENABLED, SECURITY_TIMESTAMP_WINDOW, SECURITY_NONCE_TTL
#     SECURITY_SSO_PROXY_ENABLED, SECURITY_SSO_PROXY_HEADER, SECURITY_SSO_PROXY_TRUSTED_IPS
#     AGENT_MAX_CONCURRENT, AGENT_MAX_PER_USER, AGENT_QUEUE_TIMEOUT, AGENT_EXECUTION_TIMEOUT
#     WEBUI_HOST, WEBUI_PORT, WEBUI_ALLOW_REMOTE, WEBUI_TOKEN_EXPIRY, WEBUI_TOKEN_MAX_PER_HOUR, WEBUI_QRCODE_SIZE, WEBUI_QRCODE_BORDER, WEBUI_SETUP_TOKEN
#     SQLITE_POOL_SIZE, SQLITE_BUSY_TIMEOUT_MS, DATABASE_ECHO, POSTGRES_TRANSIENT_RETRY_AFTER_SECONDS
# [S] → .env.sandbox.example only:
#     MYRM_MASTER_KEY, SANDBOX_API_KEY, CONFIG_ENCRYPTION_KEY, INTERNAL_SERVICE_KEY, CP_PUBLIC_INGRESS_URL
#     CONTROL_PLANE_URL, CONTROL_PLANE_TELEMETRY_TOKEN, CONTROL_PLANE_TELEMETRY_SUBJECT
#     TENANT_ID, SANDBOX_ID, TELEMETRY_PUSH_INTERVAL, BASELINE_SYNC_INTERVAL, PLATFORM_WU_PER_USD
#     SKILL_OPTIMIZATION_STORAGE_TYPE
#     CONTEXT_COMPACTION_TELEMETRY_BATCH_SIZE, CONTEXT_COMPACTION_TELEMETRY_FLUSH_INTERVAL_SECONDS, CONTEXT_COMPACTION_TELEMETRY_QUEUE_SIZE
#     MYRM_PUBLIC_WIKI_VOLUMES, S3_ENDPOINT_URL, S3_BUCKET_NAME, S3_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
# [T] → .env.test.example only (pytest; never production server)
# [X] Business (LLM/Embedding/Search/providers) → WebUI Settings DB only — NOT listed in any .env file

# =============================================================================
# Runtime direct reads outside AppSettings (audit index)
# =============================================================================
# DEBUG                 → app/config/env.py is_debug_mode() [O]
# DEPLOY_MODE           → app/config/deploy_mode.py [P]
# WEBUI_MODE            → deploy_mode.py [O] pairing mode (distinct from WEBUI_HOST settings)
# WEBUI_REMOTE_MODE     → deploy_mode.py [O]
# STORAGE_MODE          → deploy_mode.py [O]
# CDP_PORT              → app/config/browser.py [O] local Chrome attach
# SERVER_MODE           → run.py [O] granian multi-process (default uvicorn)
# SKIP_HEALTH_CHECK     → app/startup/health_check.py [O]
# GRANIAN_WORKERS       → app/startup/granian_runner.py [O]
# WEBUI_SETUP_TOKEN     → app/services/webui/temp_token.py [O]
# PLAYWRIGHT_BROWSERS_PATH → set at boot by env_loader.py [P] unless overridden above
# TOKENIZERS_PARALLELISM   → lifespan.py sets "false" [P] internal
# PYTEST_CURRENT_TEST   → pytest probe (platform_config.py); never set manually
