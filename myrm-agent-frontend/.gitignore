# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.benchmarks
# next.js
/.next/
/out/

# production
/build

# myrm start (local dev)
.myrm/
.myrm-dev-frontend.pid
.myrm-dev-frontend.log
.myrm-dev-frontend-fg.log

# generated locale namespace shards (SSOT: locales/*.json; run bun run i18n:split)
/locales/namespaces/

*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
frontend*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
tsconfig.tsbuildinfo
next-env.d.ts

.cursor
.kiro
WARP.md

# AI tool configs
.gemini/
.interactive_feedback_params.json

# Lock files (project uses bun)
package-lock.json

# Python script caches (scripts/check_*.py)
__pycache__/
*.py[cod]