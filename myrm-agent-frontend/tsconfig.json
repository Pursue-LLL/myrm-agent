{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "WebWorker"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [
      "node",
      "vitest/globals"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "#locales/*": [
        "./locales/*"
      ],
      "@shared/*": [
        "../shared/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "locales/**/*.json",
    "../shared/**/*.json",
    "src/**/*.mts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.ts",
    "*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-isolated-wiki-cite-e2e/types/**/*.ts",
    ".next-isolated-wiki-cite-e2e/dev/types/**/*.ts",
    ".next-isolated-e2e-parent-82523-82538-21e0f7ec/types/**/*.ts",
    ".next-isolated-e2e-parent-82523-82538-21e0f7ec/dev/types/**/*.ts",
    ".next-isolated-e2e-parent-50628-50646-5e2bac85/types/**/*.ts",
    ".next-isolated-e2e-parent-50628-50646-5e2bac85/dev/types/**/*.ts",
    ".next-isolated-e2e-parent-99261-99268-6a2f28cf/types/**/*.ts",
    ".next-isolated-e2e-parent-99261-99268-6a2f28cf/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next-isolated-*",
    "dist",
    "build"
  ]
}
