{
  "name": "myrm-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css",
    "*.scss",
    "src/styles/**/*",
    "src/app/globals.css"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:lan": "WEBUI_DEV_BIND_ALL=1 bun run scripts/dev.ts",
    "dev:clean": "bun run scripts/dev.ts --clean",
    "cleanup": "bun run scripts/cleanup.ts",
    "build": "next build",
    "build:tauri": "BUILD_MODE=tauri next build",
    "start": "next start",
    "lint": "bun node_modules/oxlint/bin/oxlint --ignore-path .oxlintignore",
    "lint:fix": "bun node_modules/oxlint/bin/oxlint --ignore-path .oxlintignore --fix",
    "lint:watch": "watch 'bun run lint' src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "check": "bun run format && bun run lint",
    "generate:artifact-types": "bun scripts/generate-artifact-types.ts",
    "sync-litellm-routing": "cd ../myrm-agent-harness && uv run python scripts/generate_litellm_routing.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "verify:i18n": "bun scripts/verify-i18n.mjs",
    "pretest": "bun run verify:i18n"
  },
  "dependencies": {
